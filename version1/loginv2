function positionDD(){
  const btn=document.getElementById('co-btn');
  const rect=btn.getBoundingClientRect();
  const dd=document.getElementById('co-dd');

  dd.style.top=(rect.bottom+6)+'px';
  dd.style.left=rect.left+'px';
  dd.style.width=rect.width+'px';
}

function toggleDD(){
  if (!currentUser) return;

  ddOpen = !ddOpen;
  const dd = document.getElementById('co-dd');

  if(ddOpen){
    positionDD();
    dd.classList.add('open');
    document.getElementById('co-btn').classList.add('open');
    const search = document.getElementById('co-search'); /*marca*/
    if (search) {
      search.value = '';   // limpia búsqueda
      search.focus();      // enfoca automáticamente
    }
  } else {
    dd.classList.remove('open');
    document.getElementById('co-btn').classList.remove('open');
  }
}

function closeDD() {
  ddOpen = false;
  document.getElementById('co-dd').classList.remove('open');
  document.getElementById('co-btn').classList.remove('open');
}

function selectCo(co) {
  selectedCompany = co;
  // Update button display
  const av = document.getElementById('co-av-sm');
  av.style.cssText = `display:flex;background:${co.clr};width:22px;height:22px;border-radius:5px;align-items:center;justify-content:center;font-size:9px;font-weight:900;color:#fff;flex-shrink:0`;
  av.textContent = co.id;
  const txt = document.getElementById('co-btn-txt');
  txt.textContent = co.nm;
  txt.classList.add('selected');
  buildDD(currentUser); // refresh checkmarks
  closeDD();
  updateLoginBtn();
}

document.addEventListener('click', e => {
  if (!e.target.closest('.co-wrap')) closeDD();
});

/* ════ ACTIVAR DROPDOWN DESPUÉS DE BLUR EN USUARIO ════ */
/*document.getElementById('inp-u').addEventListener('blur', () => {*/
document.getElementById('inp-u').addEventListener('input', () => {
  const key = normalizeUser(document.getElementById('inp-u').value);
  if (!key) return;
  // En producción: GET /api/auth/companies?user=key → companies[]
  const user = AD_USERS[key] || AD_USERS['ana']; // demo fallback
  currentUser = user;
  const btn = document.getElementById('co-btn');
  btn.disabled = false;
  buildDD(user);
  // Auto-select si solo tiene 1 empresa
  if (user.companies.length === 1) selectCo(user.companies[0]);
});

/* ════ HABILITAR BOTÓN LOGIN ════ */
function updateLoginBtn() {
  const u = document.getElementById('inp-u').value.trim();
  const p = document.getElementById('inp-p').value;
  document.getElementById('btn-login').disabled = !(u && p && selectedCompany);
}
document.getElementById('inp-u').addEventListener('input', updateLoginBtn);
document.getElementById('inp-p').addEventListener('input', updateLoginBtn);

/* ════ LOGIN ════ */
function doLogin() {
  const errEl = document.getElementById('err-login');
  errEl.classList.remove('on');
  document.querySelectorAll('.inp').forEach(i => i.classList.remove('er'));

  const u = document.getElementById('inp-u').value.trim();
  const p = document.getElementById('inp-p').value;

  if (!u) { document.getElementById('inp-u').classList.add('er'); return; }
  if (!p) { document.getElementById('inp-p').classList.add('er'); return; }
  if (!selectedCompany) return;

  // Guardar usuario si "Recordar"
  if (document.getElementById('rem').checked) {
    localStorage.setItem('snerp_saved_user', u);
  } else {
    localStorage.removeItem('snerp_saved_user');
  }

  // Simular autenticación AD (demo: cualquier pwd de 4+ chars)
  const btn = document.getElementById('btn-login');
  btn.classList.add('ld'); btn.disabled = true;

  setTimeout(() => {
    btn.classList.remove('ld'); btn.disabled = false;

    if (p.length < 4) {
      document.getElementById('err-login-txt').textContent = 'Usuario o contraseña incorrectos. Verifica tus credenciales de red.';
      errEl.classList.add('on');
      document.getElementById('inp-p').classList.add('er');
      return;
    }

    // ✅ Credenciales OK → mostrar pantalla de carga
    showLoadingScreen();
  }, 1200);
}

/* ════ PANTALLA DE CARGA ANIMADA ════ */
function showLoadingScreen() {
  showScr('s-loading');

  document.getElementById('load-company').textContent = selectedCompany.nm;
  document.getElementById('load-user').textContent = currentUser?.name || '';

  const bar = document.getElementById('load-bar');
  const msg = document.getElementById('load-msg');

  let progress = 0;

  const steps = [
    { p: 25, t: 'Validando credenciales...' },
    { p: 55, t: 'Cargando permisos...' },
    { p: 80, t: 'Preparando entorno...' },
    { p: 100, t: 'Redirigiendo...' }
  ];

  let i = 0;

  const interval = setInterval(() => {
    if (i >= steps.length) return;

    progress = steps[i].p;
    bar.style.width = progress + '%';
    msg.textContent = steps[i].t;

    i++;

    if (progress === 100) {
      clearInterval(interval);
      setTimeout(() => {
        window.location.href = 'synerERP_v3_final.html';
      }, 500);
    }

  }, 500);
}

/* ════ RESTAURAR USUARIO GUARDADO ════ */
window.addEventListener('load', () => {
  const saved = localStorage.getItem('snerp_saved_user');
  if (saved) {
    const inp = document.getElementById('inp-u');
    inp.value = saved;
    document.getElementById('rem').checked = true;
    // Cargar empresas
    const key = normalizeUser(saved);
    const user = AD_USERS[key] || AD_USERS['ana'];
    currentUser = user;
    document.getElementById('co-btn').disabled = false;
    buildDD(user);
    if (user.companies.length === 1) selectCo(user.companies[0]);
    document.getElementById('inp-p').focus();
  }
});

/* ════ ENTER para hacer submit ════ */
document.addEventListener('keydown', e => {
  if (e.key === 'Enter' && document.getElementById('s-login').classList.contains('on')) {
    doLogin();
  }
});

/* ════ Ctrl+D — demo rápido ════ */
document.addEventListener('keydown', e => {
  if (e.key === 'd' && e.ctrlKey) {
    e.preventDefault();
    document.getElementById('inp-u').value = 'ana.morales@empresa.com';
    document.getElementById('inp-p').value = 'password123';
    currentUser = AD_USERS['ana'];
    document.getElementById('co-btn').disabled = false;
    buildDD(currentUser);
    selectCo(currentUser.companies[0]);
    doLogin();
  }
});
