<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>NAF Next — Iniciar Sesión</title>
<link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --or:#e85d04;--or-dk:#c44d00;--or-lt:rgba(232,93,4,.1);
  --card:#363b36;--bd:rgba(255,255,255,.08);--bg:#282c28;
  --wh:rgba(255,255,255,.9);--soft:rgba(255,255,255,.55);--muted:rgba(255,255,255,.3);
  --font:'Lato',system-ui,sans-serif;--rad:10px;
  --sh:0 24px 64px rgba(0,0,0,.55);
}
html,body{height:100%;font-family:var(--font);background:var(--bg);display:flex;align-items:center;justify-content:center;overflow:hidden}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse 70% 50% at 15% 35%,rgba(232,93,4,.08),transparent 65%),radial-gradient(ellipse 50% 70% at 85% 75%,rgba(232,93,4,.05),transparent 65%);pointer-events:none}
body::after{content:'';position:fixed;inset:0;background-image:radial-gradient(rgba(255,255,255,.035) 1px,transparent 1px);background-size:26px 26px;pointer-events:none}

.wrap{position:relative;z-index:1;width:440px;max-width:96vw}
.card{background:var(--card);border:1px solid var(--bd);border-radius:22px;padding:38px 38px 32px;box-shadow:var(--sh);position:relative;overflow:hidden}
.card::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:220px;height:1px;background:linear-gradient(90deg,transparent,rgba(232,93,4,.7),transparent)}

/* LOGO */
.logo{display:flex;flex-direction:column;align-items:center;margin-bottom:16px}

/*.logo-mark{width:58px;height:58px;background:var(--or);border-radius:16px;display:flex;align-items:center;justify-content:center;margin-bottom:14px;box-shadow:0 10px 30px rgba(232,93,4,.4);position:relative;overflow:hidden}*/
.logo-mark{
  width:58px;
  height:58px;
  display:flex;
  align-items:center;
  justify-content:center;
  margin-bottom:6px;

  background: transparent;   /* 🔥 quita naranja */
  box-shadow: none;          /* 🔥 quita glow */
  overflow: visible;         /* 🔥 importante */
  position: relative;
}

/*.logo-mark::after{content:'';position:absolute;top:-40%;left:-20%;width:140%;height:55%;background:rgba(255,255,255,.18);transform:rotate(-18deg)}*/
.logo-mark::after{  display:none;}
.logo-g{display:grid;grid-template-columns:repeat(3,1fr);gap:4.5px;width:30px}
.logo-d{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.85)}
.logo-d.b{width:9px;height:9px;background:#fff;margin:-1px}
.logo-name{color:#fff;font-size:22px;font-weight:900;letter-spacing:-.5px}
.logo-name em{color:var(--or);font-style:normal}
.logo-tag{color:var(--muted);font-size:11.5px;letter-spacing:.3px;margin-top:3px}
.logo-line{width:32px;height:2px;background:var(--or);border-radius:2px;margin-top:11px;opacity:.55}

/* SCREENS */
.scr{display:none;animation:fu .22s ease}
.scr.on{display:block}
@keyframes fu{from{opacity:0;transform:translateY(7px)}to{opacity:1;transform:translateY(0)}}
.scr-ttl{font-size:12px;font-weight:900;color:var(--soft);text-align:center;text-transform:uppercase;letter-spacing:.9px;margin-bottom:20px}

/* AD BANNER */
.ad-banner{display:flex;align-items:center;gap:10px;background:rgba(21,101,168,.12);border:1px solid rgba(21,101,168,.2);border-radius:8px;padding:10px 13px;margin-bottom:16px}
.ad-ico{width:28px;height:28px;background:#1565a8;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.ad-txt{font-size:11px;color:rgba(255,255,255,.5);line-height:1.4}
.ad-txt strong{color:rgba(255,255,255,.78);font-size:11.5px}

/* ALERT */
.alert{display:none;padding:9px 12px;border-radius:8px;font-size:11.5px;margin-bottom:14px;line-height:1.5;gap:8px;align-items:center}
.alert.on{display:flex}
.alert-r{background:rgba(229,57,53,.1);border:1px solid rgba(229,57,53,.22);color:#ef9a9a}

/* FIELDS */
.field{margin-bottom:11px}
.fi{position:relative}
.fi-ico{position:absolute;left:13px;top:50%;transform:translateY(-50%);font-size:15px;color:var(--muted);pointer-events:none;z-index:1;transition:color .15s}
.inp{width:100%;height:48px;border-radius:var(--rad);border:1.5px solid rgba(255,255,255,.1);background:rgba(255,255,255,.06);color:#fff;font-family:var(--font);font-size:13.5px;padding:0 44px 0 42px;outline:none;transition:all .15s}
.inp::placeholder{color:var(--muted)}
.inp:focus{border-color:var(--or);background:var(--or-lt);box-shadow:0 0 0 3px rgba(232,93,4,.1)}
.inp:focus ~ .fi-ico{color:var(--or)}
.inp.er{border-color:#e53935;background:rgba(229,57,53,.06)}
.fi-eye{position:absolute;right:12px;top:50%;transform:translateY(-50%);cursor:pointer;color:var(--muted);font-size:14px;border:none;background:transparent;padding:4px;transition:color .12s;z-index:1}
.fi-eye:hover{color:var(--soft)}

/* COMPANY DROPDOWN */
.co-wrap{margin-bottom:11px;position:relative}
.co-btn{width:100%;height:48px;border-radius:var(--rad);border:1.5px solid rgba(255,255,255,.1);background:rgba(255,255,255,.06);color:var(--muted);font-family:var(--font);font-size:13px;padding:0 42px 0 13px;text-align:left;cursor:pointer;display:flex;align-items:center;gap:9px;transition:all .15s;position:relative}
.co-btn:disabled{opacity:.38;cursor:not-allowed}
.co-btn:not(:disabled):hover{border-color:rgba(255,255,255,.22);background:rgba(255,255,255,.09)}
.co-btn:not(:disabled).open{border-color:var(--or);background:var(--or-lt)}
.co-av-sm{width:22px;height:22px;border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:900;color:#fff;flex-shrink:0}
.co-btn-txt{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.co-btn-txt.selected{color:#fff;font-weight:700}
.co-arr{position:absolute;right:13px;top:50%;transform:translateY(-50%);font-size:11px;color:var(--muted);transition:transform .15s}
.co-btn.open .co-arr{transform:translateY(-50%) rotate(180deg);color:var(--or)}
/* dropdown panel */
.co-dd{position:absolute;top:calc(100% + 5px);left:0;right:0;z-index:100;background:#252a25;border:1px solid rgba(255,255,255,.1);border-radius:var(--rad);box-shadow:0 12px 36px rgba(0,0,0,.5);display:none;max-height: 260px;overflow-y: auto;overflow-x: hidden;}
.co-dd.open{display:block}
.co-dd-item{display:flex;align-items:center;gap:10px;padding:10px 13px;cursor:pointer;border-bottom:1px solid rgba(255,255,255,.05);transition:background .1s}
.co-dd-item:last-child{border-bottom:none}
.co-dd-item:hover{background:rgba(255,255,255,.06)}
.co-dd-item.sel{background:rgba(232,93,4,.09)}
.co-av{width:34px;height:34px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:900;color:#fff;flex-shrink:0}
.co-info{flex:1;min-width:0}
.co-nm{color:#fff;font-size:12.5px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.co-ruc{color:var(--muted);font-size:10px;margin-top:1px}
.co-role{font-size:9px;font-weight:900;padding:2px 7px;border-radius:20px;display:inline-block;margin-top:3px}
.rb-admin{background:rgba(232,93,4,.2);color:#ffa07a}
.rb-user{background:rgba(255,255,255,.08);color:rgba(255,255,255,.45)}
.rb-ro{background:rgba(21,101,168,.2);color:#90caf9}
.co-chk{font-size:14px;color:var(--or);flex-shrink:0;opacity:0}
.co-dd-item.sel .co-chk{opacity:1}
.co-hint{font-size:10px;color:var(--muted);margin-top:-7px;margin-bottom:11px;padding-left:2px}

/* CHECKBOX & LINK */
.row-bot{display:flex;align-items:center;justify-content:space-between;margin-top:2px;margin-bottom:2px}
.chk-l{display:flex;align-items:center;gap:7px;cursor:pointer}
.chk{width:15px;height:15px;border-radius:4px;border:1.5px solid rgba(255,255,255,.2);background:transparent;cursor:pointer;appearance:none;-webkit-appearance:none;flex-shrink:0;transition:all .15s;position:relative}
.chk:checked{background:var(--or);border-color:var(--or)}
.chk:checked::after{content:'✓';position:absolute;top:50%;left:50%;transform:translate(-50%,-52%);color:#fff;font-size:9px;font-weight:900}
.chk-lbl{font-size:11.5px;color:var(--muted);user-select:none}
.link{color:var(--or);font-size:11.5px;font-weight:700;cursor:pointer;background:none;border:none;font-family:var(--font);transition:opacity .12s}
.link:hover{opacity:.7}

/* BUTTON */
.btn-p{width:100%;height:50px;border-radius:var(--rad);border:none;background:var(--or);color:#fff;font-family:var(--font);font-size:14.5px;font-weight:900;cursor:pointer;letter-spacing:.3px;position:relative;overflow:hidden;margin-top:18px;transition:all .15s;display:flex;align-items:center;justify-content:center}
.btn-p::before{content:'';position:absolute;inset:0;background:linear-gradient(to bottom,rgba(255,255,255,.1),transparent);pointer-events:none}
.btn-p:hover:not(:disabled){background:var(--or-dk);transform:translateY(-1px);box-shadow:0 6px 24px rgba(232,93,4,.42)}
.btn-p:active{transform:translateY(0)}
.btn-p:disabled{opacity:.4;cursor:not-allowed;transform:none}
.spinner{display:none;width:20px;height:20px;border:2.5px solid rgba(255,255,255,.25);border-top-color:#fff;border-radius:50%;animation:spin .55s linear infinite}
.btn-p.ld .btn-txt{display:none}.btn-p.ld .spinner{display:block}
@keyframes spin{to{transform:rotate(360deg)}}

/* ── LOADING SCREEN ── */
#s-loading{background:var(--bg)}
.load-inner{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:260px;gap:0}
.load-logo-mark{width:64px;height:64px;background:var(--or);border-radius:18px;display:flex;align-items:center;justify-content:center;box-shadow:0 12px 32px rgba(232,93,4,.45);position:relative;overflow:hidden;animation:pulse 2s ease infinite}
.load-logo-mark::after{content:'';position:absolute;top:-40%;left:-20%;width:140%;height:55%;background:rgba(255,255,255,.18);transform:rotate(-18deg)}
@keyframes pulse{0%,100%{box-shadow:0 12px 32px rgba(232,93,4,.45)}50%{box-shadow:0 12px 44px rgba(232,93,4,.7)}}
.load-logo-g{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;width:34px}
.load-logo-d{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.85)}
.load-logo-d.b{width:10px;height:10px;background:#fff;margin:-1px}
.load-name{color:#fff;font-size:24px;font-weight:900;letter-spacing:-.5px;margin-top:16px}
.load-name em{color:var(--or);font-style:normal}
.load-company{margin-top:6px;font-size:13px;color:var(--soft);font-weight:700}
.load-role{font-size:11px;color:var(--muted);margin-top:3px}
.load-bar-wrap{width:200px;height:3px;background:rgba(255,255,255,.08);border-radius:3px;margin-top:28px;overflow:hidden}
.load-bar{height:100%;background:linear-gradient(90deg,var(--or),#ff8c42);border-radius:3px;width:0;transition:width .15s ease}
.load-msg{font-size:11px;color:var(--muted);margin-top:12px;height:16px;text-align:center;transition:opacity .3s}

/* FORGOT */
.f-cards{display:flex;flex-direction:column;gap:8px;margin-bottom:4px}
.f-card{display:flex;align-items:center;gap:12px;padding:12px 13px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:9px}
.f-card-ico{width:32px;height:32px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.f-card-t{color:#fff;font-size:12.5px;font-weight:700;margin-bottom:2px}
.f-card-s{color:var(--muted);font-size:11px}

/* FOOTER */
.footer{text-align:center;margin-top:18px;font-size:10px;color:rgb(255, 255, 255);line-height:1.7}
.footer em{color:var(--or);font-style:normal}

html,body{
  overflow-x:hidden !important;
  overflow-y:auto !important;
}

.card{
  overflow:visible !important;
}

.co-dd{
  position:fixed !important;
  z-index:99999 !important;
  max-height:260px;
  overflow-y:auto;
  overflow-x:hidden;
}
/* TODO tu CSS original */
  .co-search {
    padding: 8px;
    border-bottom: 1px solid rgba(255,255,255,.08);
  }

  .co-search input {
    width: 100%;
    height: 34px;
    border-radius: 6px;
    border: none;
    outline: none;
    padding: 0 8px;
    background: rgba(255,255,255,.08);
    color: #fff;
    font-size: 12px;
  }

.co-dd::-webkit-scrollbar {
  width: 6px;
}

.co-dd::-webkit-scrollbar-thumb {
  background: rgba(255,255,255,.2);
  border-radius: 4px;
}

.logo-img{
  width:300px;
  height:300px;
  object-fit:contain;

    filter:
    drop-shadow(0 0 1px rgba(255,255,255,.6))  /* 🔥 contorno blanco */
    drop-shadow(0 3px 8px rgba(0,0,0,.9))      /* profundidad */
    drop-shadow(0 0 6px rgba(232,93,4,.4));    /* glow marca */
}

.load-simple{
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  min-height:260px;
  gap:14px;
}

.logo-img-load{
  width:60px;
  filter:
    drop-shadow(0 3px 8px rgba(0,0,0,.8))
    drop-shadow(0 0 6px rgba(232,93,4,.4));
}

.load-title{
  font-size:13px;
  color: rgba(255,255,255,.6);
  font-weight:600;
}

.load-bar-simple{
  width:140px;
  height:3px;
  background: rgba(255,255,255,.08);
  border-radius:2px;
  overflow:hidden;
}

.load-bar-fill{
  height:100%;
  width:0;
  background: var(--or);
  transition: width .2s ease;
}

.load-sub{
  font-size:11px;
  color:rgba(255,255,255,.45);
  margin-top:-6px;
}

.load-welcome{
  font-size:16px;
  font-weight:700;
  color:#fff;
}

.load-msg{
  font-size:11px;
  color:rgba(255,255,255,.4);
  height:16px;
  margin-top:-6px;
}

.load-check{
  width:58px;
  height:58px;
  border-radius:14px;
  background:linear-gradient(135deg,#66bb6a,#43a047);
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:28px;
  color:#fff;
  font-weight:900;

  transform-origin:center;

  box-shadow:
    0 8px 24px rgba(76,175,80,.45),
    inset 0 1px 2px rgba(255,255,255,.25);

  animation: pop .35s ease, glow 1.2s ease infinite alternate;
}

@keyframes pop{
  0%{
    transform: scale(.6);
    opacity: 0;
  }
  100%{
    transform: scale(1);
    opacity: 1;
  }
}

@keyframes glow{
  from{
    box-shadow:
      0 6px 20px rgba(76,175,80,.4),
      inset 0 1px 2px rgba(255,255,255,.25);
  }
  to{
    box-shadow:
      0 12px 32px rgba(76,175,80,.7),
      inset 0 1px 2px rgba(255,255,255,.25);
  }
}

</style>
</head>
