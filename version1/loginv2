<script>
/* ════════════════════════════════════════════════════════
   DATOS SIMULADOS DE AD
   En producción: POST /api/auth/validate-user → { companies[] }
   luego: POST /api/auth/login → { token, user, role }
════════════════════════════════════════════════════════ */
const AD_USERS = {
  'ana': {
    name:'Ana Morales',
    companies:[
      {id:'EP', nm:'L.HENRIQUES & CIA S.A.',  ruc:'0990331928001', clr:'#e85d04'},
      {id:'FN', nm:'NUTRIHOME S.A.', ruc:'0992600950001', clr:'#555'},
      {id:'MS', nm:'PROHOME S.A.',    ruc:'0992635622001', clr:'#2e7d32'},
      {id:'CI', nm:'MASCORP S.A.',  ruc:'0991174192001', clr:'#8d292b'},
    ]
  },
  'juan': {
    name:'Juan Pérez',
    companies:[
      {id:'FN', nm:'NUTRIHOME S.A.', ruc:'0992600950001', clr:'#555'},
    ]
  },
  'maria': {
    name:'María García', role:'Auditora',
    companies:[
      {id:'EP', nm:'L.HENRIQUES & CIA S.A.',  ruc:'0990331928001', clr:'#e85d04'},
      {id:'FN', nm:'NUTRIHOME S.A.', ruc:'0992600950001', clr:'#555'},
    ]
  }
};

/* ════ ESTADO ════ */
let currentUser = null;
let selectedCompany = null;
let ddOpen = false;

/* ════ NORMALIZAR USUARIO ════ */
function normalizeUser(v) {
  return v.trim().toLowerCase().split('@')[0].split('.')[0];
}

/* ════ SCREENS ════ */
function showScr(id) {
  document.querySelectorAll('.scr').forEach(s => s.classList.remove('on'));
  document.getElementById(id).classList.add('on');
}

/* ════ TOGGLE PASSWORD ════ */
function togglePwd() {
  const inp = document.getElementById('inp-p');
  const btn = document.getElementById('eye-btn');
  if (inp.type === 'password') { inp.type = 'text'; btn.textContent = '🙈'; }
  else { inp.type = 'password'; btn.textContent = '👁'; }
}

/* ════ COMPANY DROPDOWN ════ */
function buildDD(user) {
  const list = document.getElementById('co-list');

  // limpiar solo la lista (NO el buscador)
  list.innerHTML = '';

  user.companies.forEach(co => {
    const item = document.createElement('div');
    item.className = 'co-dd-item' + (selectedCompany?.id === co.id ? ' sel' : '');

    item.innerHTML = `
      <div class="co-av" style="background:${co.clr}">${co.id}</div>
      <div class="co-info">
        <div class="co-nm">${co.nm}</div>
        <div class="co-ruc">RUC: ${co.ruc}</div>
      </div>
      <span class="co-chk">✓</span>
    `;

    item.onclick = () => selectCo(co);

    list.appendChild(item);
  });
}
