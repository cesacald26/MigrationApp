    </div>

    <button class="btn-primary" id="btn-empresa" onclick="doSelectEmpresa()" disabled>
      <div class="btn-txt">Ingresar al sistema</div>
      <div class="spinner"></div>
    </button>
    <button class="btn-ghost" onclick="goBack('s1')">← Volver</button>
  </div>

  <!-- ════════════════════════════════
       SCREEN 3 — CARGANDO / ÉXITO
  ════════════════════════════════ -->
  <div class="screen" id="s3">
    <div style="display:flex;flex-direction:column;align-items:center;padding:16px 0 8px;gap:14px">
      <!--<img src="logo.png" style="width:72px;height:auto;object-fit:contain;filter:drop-shadow(0 3px 10px rgba(0,0,0,.7)) drop-shadow(0 0 8px rgba(232,93,4,.4))">-->
      <div class="load-check">✓</div>
      <div style="font-size:17px;font-weight:900;color:#fff">¡Bienvenido, <span id="success-nm">Ana</span>!</div>
      <div style="font-size:13px;color:rgba(255,255,255,.6)">Ingresando a <strong id="success-emp" style="color:rgba(255,255,255,.85)">L.HENRIQUES & CIA S.A.</strong></div>
