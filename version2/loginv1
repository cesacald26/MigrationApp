let currentUser = null, selectedCompany = null;

/* ════ SCREEN MANAGEMENT ════ */
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  updateSteps(id);
}
function updateSteps(id){
  const map={s1:0,s1b:0,s2:1,s3:2,s4:0};
  const idx=map[id]??0;
  [0,1,2].forEach((i,_)=>{
    const el=document.getElementById('st'+(i+1));
    el.className='step'+(i<idx?' done':i===idx?' active':'');
  });
}
function goBack(target){ showScreen(target); clearErrors(); }

/* ════ PASSWORD TOGGLE ════ */
function togglePwd(){
  const inp=document.getElementById('inp-pass');
  const btn=document.getElementById('eye-btn');
  if(inp.type==='password'){inp.type='text';btn.textContent='🙈'}
  else{inp.type='password';btn.textContent='👁'}
}

/* ════ CLEAR ERRORS ════ */
function clearErrors(){
  document.querySelectorAll('.alert').forEach(a=>a.classList.remove('show'));
  document.querySelectorAll('.inp').forEach(i=>i.classList.remove('err'));
  document.querySelectorAll('.err-msg').forEach(e=>e.classList.remove('show'));
}

/* ════ LOGIN FLOW ════ */
function doLogin(){
  clearErrors();
  const username = document.getElementById('inp-user').value.trim().toLowerCase().replace('@empresa.com','').replace(/\..+/,''); // normalize
  const password = document.getElementById('inp-pass').value;

  if(!username){
    document.getElementById('inp-user').classList.add('err');
    showErr('err1','Por favor ingresa tu usuario corporativo.');
    return;
  }
  if(!password){
    document.getElementById('inp-pass').classList.add('err');
    showErr('err1','Por favor ingresa tu contraseña.');
    return;
  }

  const btn=document.getElementById('btn-login');
  btn.classList.add('loading'); btn.disabled=true;

  // Simulate AD auth (1.2s delay)
  setTimeout(()=>{
    btn.classList.remove('loading'); btn.disabled=false;

    // Try to find user (demo: any of our test users, or fail)
    const user = USERS[username] || USERS['ana.morales']; // demo fallback
    const isValid = password.length >= 4; // demo: any 4+ char password works

    if(!isValid){
      showErr('err1','Usuario o contraseña incorrectos. Verifica tus credenciales de red.');
      document.getElementById('inp-user').classList.add('err');
      document.getElementById('inp-pass').classList.add('err');
      return;
    }

    currentUser = user;

    // Save username if remember checked
    if(document.getElementById('remember').checked){
      localStorage.setItem('syneremp_user', document.getElementById('inp-user').value);
    }

    if(user.mfa){
      // Go to 2FA screen
      document.getElementById('av-2fa').textContent=user.initials;
      document.getElementById('nm-2fa').textContent=user.name;
      showScreen('s1b');
    } else {
      afterAuth();
    }
  }, 1200);
}


/* ════ AFTER AUTH — siempre mostrar selector de empresa ════ */
function afterAuth(){
  const user = currentUser;
  // Siempre mostrar selector — todos los usuarios ven todas las empresas
  buildCompanyGrid(user);
  document.getElementById('av-s2').textContent=user.initials;
  document.getElementById('nm-s2').textContent=user.name;
  showScreen('s2');
}

/* ════ BUILD COMPANY GRID ════ */
function buildCompanyGrid(user){
  const grid=document.getElementById('company-grid');
  grid.innerHTML='';
  user.companies.forEach(co=>{
    const card=document.createElement('div');
    card.className='company-card';
    card.innerHTML=`
      <div class="c-av" style="background:${co.color}">${co.id}</div>
      <div class="c-info">
        <div class="c-nm">${co.name}</div>
        <div class="c-ruc">RUC: ${co.ruc}</div>
      </div>
      <div class="c-check"></div>`;
    card.onclick=()=>selectCompany(card,co);
    grid.appendChild(card);
  });
}

/* ════ SELECT COMPANY ════ */
function selectCompany(card, co){
  document.querySelectorAll('.company-card').forEach(c=>c.classList.remove('selected'));
  card.classList.add('selected');
  card.querySelector('.c-check').textContent='✓';
  selectedCompany=co;
  document.getElementById('btn-empresa').disabled=false;
}

/* ════ ENTER SYSTEM ════ */
function doSelectEmpresa(){
  const btn=document.getElementById('btn-empresa');
  btn.classList.add('loading'); btn.disabled=true;
  setTimeout(goToSuccess, 800);
}

function goToSuccess(){
  document.getElementById('success-nm').textContent=currentUser.short;
  document.getElementById('success-emp').textContent=selectedCompany.name;
  showScreen('s3');
  // Barra animada en pasos
  const bar = document.getElementById('progress-fill');
  const msg = document.getElementById('load-msg-s3');
  const steps = [
    {p:25, t:'Validando credenciales…'},
    {p:55, t:'Cargando permisos…'},
    {p:80, t:'Preparando entorno…'},
    {p:100,t:'Redirigiendo al portal…'}
  ];
  let i=0;
  const iv = setInterval(()=>{
    if(i>=steps.length){clearInterval(iv);return;}
    bar.style.width=steps[i].p+'%';
    if(msg) msg.textContent=steps[i].t;
    i++;
    if(steps[i-1].p===100){
      clearInterval(iv);
      setTimeout(()=>{ window.location.href='synerERP_v3_final.html'; },400);
    }
  },500);
}


/* ════ HELPERS ════ */
function showErr(id, msg){
  const el=document.getElementById(id);
  const txtEl=document.getElementById(id+'-txt');
  if(txtEl) txtEl.textContent=msg;
  el.classList.add('show');
}
function showForgot(){ showScreen('s4'); }

/* ════ KEYBOARD ════ */
document.addEventListener('keydown',e=>{
  if(e.key==='Enter'){
    const active=document.querySelector('.screen.active');
    if(active.id==='s1') doLogin();
    if(active.id==='s1b') doOTP();
    if(active.id==='s2') doSelectEmpresa();
  }
});

/* ════ RESTORE SAVED USER ════ */
window.addEventListener('load',()=>{
  const saved=localStorage.getItem('syneremp_user');
  if(saved){
    document.getElementById('inp-user').value=saved;
    document.getElementById('remember').checked=true;
    document.getElementById('inp-pass').focus();
  }
});

