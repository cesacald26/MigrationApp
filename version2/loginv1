    </div>
  </div>

  <!-- ════════════════════════════════
       SCREEN 4 — CONTRASEÑA OLVIDADA
  ════════════════════════════════ -->
  <div class="screen" id="s4">
    <div class="scr-title">Recuperar acceso</div>
    <div style="text-align:center;font-size:12px;color:rgba(255,255,255,.5);margin-bottom:16px;line-height:1.5">
      Tu contraseña la gestiona el <strong style="color:rgba(255,255,255,.7)">Active Directory corporativo</strong>.<br>
      Contacta a soporte TI para restablecerla.
    </div>
    <div class="alert alert-info show" style="margin-bottom:14px">
      <span>💡</span>
      <div>
        <div style="font-weight:700;color:rgba(255,255,255,.75);margin-bottom:3px">Opciones de recuperación</div>
        <div>• Mesa de ayuda TI: ext. <strong>1234</strong></div>
        <div>• Correo: <strong>soporte@empresa.com</strong></div>
      </div>
    </div>
    <button class="btn-primary" onclick="goBack('s1')">← Volver al inicio de sesión</button>
  </div>

</div><!-- /card -->

<div class="card-footer">
