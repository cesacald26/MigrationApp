<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>NAF Next — Iniciar Sesión</title>
<link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --or:#e85d04;--or-dk:#c44d00;--or-lt:#fff3eb;
  --card:#3a3f3a;--card-dk:#2e322e;--card-bd:rgba(255,255,255,0.07);
  --bg:#2a2e2a;
  --inp:#f0f4f0;--inp-bd:rgba(255,255,255,.06);
  --tx-wh:#ffffff;--tx-muted:rgba(255,255,255,.45);--tx-soft:rgba(255,255,255,.65);
  --font:'Lato',system-ui,sans-serif;--rad:12px;--rad-sm:8px;
  --sh:0 20px 60px rgba(0,0,0,0.45);--sh-sm:0 4px 16px rgba(0,0,0,0.25);
}
html,body{height:100%;font-family:var(--font);background:var(--bg);display:flex;align-items:center;justify-content:center;min-height:100vh;overflow:hidden}

/* ── BACKGROUND PATTERN ── */
/*body::before{
  content:'';position:fixed;inset:0;
  background:radial-gradient(ellipse 80% 60% at 20% 40%,rgba(232,93,4,0.07) 0%,transparent 60%),
             radial-gradient(ellipse 60% 80% at 80% 70%,rgba(232,93,4,0.04) 0%,transparent 60%);
  pointer-events:none;z-index:0
}*/
/* grid dots */
/*body::after{
  content:'';position:fixed;inset:0;
  background-image:radial-gradient(rgba(255,255,255,0.04) 1px,transparent 1px);
  background-size:28px 28px;pointer-events:none;z-index:0
}*/

/* ── CARD WRAPPER (handles transitions) ── */
.wrap{position:relative;z-index:1;width:440px}
.card{
  background:var(--card);border:1px solid var(--card-bd);
  border-radius:20px;padding:24px;
  box-shadow:var(--sh);position:relative;overflow:hidden;
  padding:22px 22px 24px;
}
/* subtle inner glow top */
.card::before{
  content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);
  width:200px;height:1px;
  background:linear-gradient(90deg,transparent,rgba(232,93,4,0.6),transparent)
}

/* ── LOGO ── */
.logo-wrap{display:flex;flex-direction:column;align-items:center;margin-bottom:0}
.logo-mark{
  background:transparent !important;
  box-shadow:none !important;
  padding:0 !important;
  margin-bottom:6px;   /* 🔥 antes 14px */
  display:flex;
  justify-content:center;
  position:relative;
}

.logo-mark::before{
  display: none;
}

.logo-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:4px;width:28px}
.logo-dot{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,0.9)}
.logo-dot.big{width:9px;height:9px;background:#fff;margin:-1px}
.logo-title{color:var(--tx-wh);font-size:20px;font-weight:900;letter-spacing:-.4px;text-align:center}
.logo-title span{color:var(--or)}
.logo-sub{color:var(--tx-muted);font-size:12px;margin-top:2px;letter-spacing:.3px}
.logo-divider{width:36px;height:2px;background:var(--or);border-radius:2px;margin:4px auto 6px;opacity:.6}

/* ── SCREEN SYSTEM ── */
.screen{display:none;animation:fadeUp .22s ease}
.screen.active{display:block}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* ── STEP INDICATOR ── */
.steps{display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:20px}
.step{width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,0.15);transition:all .25s}
.step.done{background:var(--or);opacity:.5}
.step.active{background:var(--or);width:20px;border-radius:3px}

/* ── SCREEN TITLE ── */
.scr-title{color:var(--tx-soft);font-size:12.5px;font-weight:700;text-align:center;margin-bottom:18px;text-transform:uppercase;letter-spacing:.8px}

/* ── AD BANNER ── */
.ad-banner{
  display:flex;align-items:center;gap:10px;
  background:rgba(21,101,168,0.15);border:1px solid rgba(21,101,168,0.25);
  border-radius:var(--rad-sm);padding:10px 13px;margin-bottom:16px
}
.ad-ico{width:28px;height:28px;border-radius:6px;background:#1565a8;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.ad-txt{font-size:11px;color:rgba(255,255,255,.55);line-height:1.4}
.ad-txt strong{color:rgba(255,255,255,.8);font-size:11.5px}

/* ── INPUTS ── */
.field{margin-bottom:12px;position:relative}
.field-label{font-size:10.5px;font-weight:700;color:var(--tx-muted);text-transform:uppercase;letter-spacing:.7px;margin-bottom:5px;display:block}
.inp-wrap{position:relative}
.inp-ico{position:absolute;left:13px;top:50%;transform:translateY(-50%);font-size:15px;color:rgba(255,255,255,.3);pointer-events:none;transition:color .15s}
.inp{
  width:100%;height:46px;border-radius:var(--rad-sm);border:1.5px solid rgba(255,255,255,.1);
  background:rgba(255,255,255,.07);color:var(--tx-wh);font-family:var(--font);font-size:13.5px;
  padding:0 42px 0 40px;outline:none;transition:all .15s;
  -webkit-autofill:{background:transparent}
}
.inp::placeholder{color:rgba(255,255,255,.25)}
.inp:focus{border-color:var(--or);background:rgba(232,93,4,0.06);box-shadow:0 0 0 3px rgba(232,93,4,0.12)}
.inp:focus~.inp-ico,.inp-wrap:focus-within .inp-ico{color:var(--or)}
.inp-eye{position:absolute;right:12px;top:50%;transform:translateY(-50%);cursor:pointer;color:rgba(255,255,255,.3);font-size:15px;border:none;background:transparent;padding:4px;transition:color .15s}
.inp-eye:hover{color:rgba(255,255,255,.65)}
.inp.err{border-color:#e53935;background:rgba(229,57,53,0.06)}
.err-msg{font-size:11px;color:#ef9a9a;margin-top:4px;display:none}
.err-msg.show{display:block}

/* ── CHECKBOX ── */
.check-row{display:flex;align-items:center;gap:8px;margin-top:4px}
.chk{width:15px;height:15px;border-radius:4px;border:1.5px solid rgba(255,255,255,.2);background:transparent;cursor:pointer;appearance:none;-webkit-appearance:none;flex-shrink:0;position:relative;transition:all .15s}
.chk:checked{background:var(--or);border-color:var(--or)}
.chk:checked::after{content:'✓';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);color:#fff;font-size:9px;font-weight:900}
.chk-lbl{font-size:11.5px;color:var(--tx-muted);cursor:pointer;user-select:none}

/* ── BUTTONS ── */
.btn-primary{
  width:100%;height:48px;border-radius:var(--rad-sm);border:none;
  background:var(--or);color:#fff;font-family:var(--font);font-size:14px;font-weight:900;
  cursor:pointer;transition:all .15s;letter-spacing:.3px;position:relative;overflow:hidden;
  margin-top:18px
}
.btn-primary::before{content:'';position:absolute;inset:0;background:linear-gradient(to bottom,rgba(255,255,255,0.1),transparent);pointer-events:none}
.btn-primary:hover{background:var(--or-dk);transform:translateY(-1px);box-shadow:0 6px 20px rgba(232,93,4,0.35)}
.btn-primary:active{transform:translateY(0)}
.btn-primary:disabled{opacity:.5;cursor:not-allowed;transform:none}
.btn-primary .spinner{display:none;width:18px;height:18px;border:2.5px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .6s linear infinite;margin:0 auto}
.btn-primary.loading .btn-txt{display:none}
.btn-primary.loading .spinner{display:block}
@keyframes spin{to{transform:rotate(360deg)}}

.btn-ghost{
  width:100%;height:38px;border-radius:var(--rad-sm);border:1.5px solid rgba(255,255,255,.12);
  background:transparent;color:rgba(255,255,255,.55);font-family:var(--font);font-size:12.5px;font-weight:700;
  cursor:pointer;transition:all .15s;margin-top:8px
}
.btn-ghost:hover{border-color:rgba(255,255,255,.25);color:rgba(255,255,255,.8);background:rgba(255,255,255,.04)}

/* ── COMPANY SELECTOR ── */
.company-grid{display:flex;flex-direction:column;gap:8px;margin-bottom:4px}
.company-card{
  display:flex;align-items:center;gap:12px;padding:12px 14px;
  border-radius:var(--rad-sm);border:1.5px solid rgba(255,255,255,.1);
  background:rgba(255,255,255,.04);cursor:pointer;transition:all .18s;position:relative
}
.company-card:hover{border-color:rgba(232,93,4,.4);background:rgba(232,93,4,.05)}
.company-card.selected{border-color:var(--or);background:rgba(232,93,4,.08);box-shadow:0 0 0 3px rgba(232,93,4,.1)}
.company-card.locked{opacity:.38;cursor:not-allowed;pointer-events:none}
.c-av{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:900;color:#fff;flex-shrink:0}
.c-info{flex:1;min-width:0}
.c-nm{color:var(--tx-wh);font-size:13px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.c-ruc{color:var(--tx-muted);font-size:10.5px;margin-top:1px}
.c-role{font-size:9.5px;font-weight:900;padding:2px 7px;border-radius:20px;margin-top:3px;display:inline-block}
.r-admin{background:rgba(232,93,4,.2);color:#ffa07a}
.r-user{background:rgba(255,255,255,.08);color:rgba(255,255,255,.5)}
.r-readonly{background:rgba(21,101,168,.2);color:#90caf9}
.c-check{width:20px;height:20px;border-radius:50%;border:2px solid rgba(255,255,255,.2);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .18s}
.company-card.selected .c-check{background:var(--or);border-color:var(--or);color:#fff;font-size:11px}
.lock-ico{position:absolute;top:8px;right:10px;font-size:11px;opacity:.5}

/* ── USER INFO BADGE (screen 2 & 3) ── */
.user-badge{
  display:flex;align-items:center;gap:10px;padding:10px 13px;
  background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);
  border-radius:var(--rad-sm);margin-bottom:16px
}
.user-av{width:32px;height:32px;border-radius:50%;background:var(--or);color:#fff;font-size:11px;font-weight:900;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.user-nm{color:var(--tx-wh);font-size:12.5px;font-weight:700}
.user-sub{color:var(--tx-muted);font-size:10.5px}
.user-badge-change{margin-left:auto;font-size:10.5px;color:var(--or);cursor:pointer;font-weight:700;flex-shrink:0;border:none;background:transparent;padding:2px 6px;border-radius:4px;transition:background .1s}
.user-badge-change:hover{background:rgba(232,93,4,.12)}

/* ── FORGOT / HELP ── */
.link{color:var(--or);font-size:11.5px;font-weight:700;cursor:pointer;background:none;border:none;font-family:var(--font);transition:opacity .1s;text-decoration:none;display:inline}
.link:hover{opacity:.75}
.row-help{display:flex;align-items:center;justify-content:space-between;margin-top:4px}

.sso-btn:hover{border-color:rgba(255,255,255,.22);background:rgba(255,255,255,.07);color:#fff}

/* ── ALERT ── */
.alert{display:none;padding:10px 13px;border-radius:var(--rad-sm);font-size:12px;margin-bottom:12px;line-height:1.5}
.alert.show{display:flex;align-items:center;gap:8px}
.alert-err{background:rgba(229,57,53,.12);border:1px solid rgba(229,57,53,.25);color:#ef9a9a}
.alert-ok{background:rgba(30,139,69,.12);border:1px solid rgba(30,139,69,.25);color:#81c995}
.alert-info{background:rgba(21,101,168,.12);border:1px solid rgba(21,101,168,.25);color:#90caf9}

/* ── FOOTER ── */
.card-footer{text-align:center;margin-top:20px;font-size:10.5px;color:rgb(255, 255, 255)}
.card-footer span{color:var(--or)}

/* ── SUCCESS STATE ── */
.success-ico{font-size:44px;text-align:center;margin-bottom:12px;animation:pop .3s cubic-bezier(.34,1.56,.64,1)}
@keyframes pop{from{transform:scale(.5);opacity:0}to{transform:scale(1);opacity:1}}
.success-txt{color:var(--tx-wh);font-size:16px;font-weight:900;text-align:center;margin-bottom:6px}
.success-sub{color:var(--tx-muted);font-size:12px;text-align:center;line-height:1.5}
.progress-bar{height:3px;background:rgba(255,255,255,.1);border-radius:2px;margin-top:18px;overflow:hidden}
.progress-fill{height:100%;background:var(--or);border-radius:2px;animation:progress 2s ease forwards}
@keyframes progress{from{width:0}to{width:100%}}

/* ── COMPANY SWITCHER INFO (in-app) ── */
.readonly-badge{
  display:inline-flex;align-items:center;gap:5px;background:rgba(21,101,168,.15);
  border:1px solid rgba(21,101,168,.25);border-radius:20px;
  padding:3px 10px;font-size:10.5px;color:#90caf9;font-weight:700;margin-bottom:16px
}
.logo-img {
  width: 500px;
  height: 500px;
  object-fit: contain;
  filter: drop-shadow(0 2px 8px rgba(0,0,0,.6)) drop-shadow(0 0 5px rgba(232,93,4,.3));
}

.logo-img-main{
  width:260px;
  max-width:100%;
  height:auto;
  object-fit:contain;
  transition: all .3s ease;

  /* 🔥 CONTORNO + GLOW PRO */
  /*filter:
    drop-shadow(0 2px 2px rgba(0,0,0,.9))     /* borde oscuro */
    drop-shadow(0 4px 8px rgba(0,0,0,.6))     /* profundidad */
    drop-shadow(0 0 6px rgba(232,93,4,.6))    /* glow naranja */
    drop-shadow(0 0 12px rgba(232,93,4,.35)); /* glow externo */
}*/

.logo-img-main:hover{
  filter:
    drop-shadow(1px 0 0 rgba(0,0,0,1))
    drop-shadow(-1px 0 0 rgba(0,0,0,1))
    drop-shadow(0 1px 0 rgba(0,0,0,1))
    drop-shadow(0 -1px 0 rgba(0,0,0,1))
    drop-shadow(0 6px 16px rgba(0,0,0,.8))
    drop-shadow(0 0 12px rgba(232,93,4,.9));
}

.load-check{
  width:58px;
  height:58px;
  border-radius:14px;
  background:linear-gradient(135deg,#66bb6a,#43a047);
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:28px;
  color:#fff;
  font-weight:900;

  transform-origin:center;

  box-shadow:
    0 8px 24px rgba(76,175,80,.45),
    inset 0 1px 2px rgba(255,255,255,.25);

  animation: pop .35s ease, glow 1.2s ease infinite alternate;
}

</style>
</head>
